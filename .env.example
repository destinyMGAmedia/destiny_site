# ─────────────────────────────────────────────
# DATABASE — Vercel Postgres (Neon)
# Get these from: Vercel Dashboard → Storage → Postgres → .env.local tab
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─────────────────────────────────────────────
# NEXTAUTH
# NEXTAUTH_SECRET: run `openssl rand -base64 32` to generate
# NEXTAUTH_URL: your deployed URL (or http://localhost:3000 for dev)
# ─────────────────────────────────────────────
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# CLOUDINARY
# Get these from: cloudinary.com → Dashboard
# ─────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─────────────────────────────────────────────
# YOUTUBE (optional — needed for dynamic playlist fetching)
# Get from: console.cloud.google.com → YouTube Data API v3
# Not needed for simple embeds
# ─────────────────────────────────────────────
YOUTUBE_API_KEY="your-youtube-api-key"

# ─────────────────────────────────────────────
# GLOBAL ADMIN SEED (used only during initial setup)
# ─────────────────────────────────────────────
SEED_ADMIN_EMAIL="admin@destinymissions.org"
SEED_ADMIN_PASSWORD="global123"
SEED_ADMIN_NAME="Global Administrator"
